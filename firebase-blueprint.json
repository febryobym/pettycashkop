{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "A representation of a financial transaction (income, expense, or transfer)",
      "type": "object",
      "properties": {
        "date": {
          "type": "string",
          "format": "date",
          "description": "The date of the transaction"
        },
        "description": {
          "type": "string",
          "description": "The physical description/note of the transaction"
        },
        "amount": {
          "type": "number",
          "description": "The final amount of the transaction after rounding"
        },
        "type": {
          "type": "string",
          "enum": ["income", "expense", "transfer"],
          "description": "The transaction classification"
        },
        "categoryId": {
          "type": "string",
          "description": "References the Category collection ID"
        },
        "accountId": {
          "type": "string",
          "description": "References the source Account ID"
        },
        "toAccountId": {
          "type": "string",
          "description": "References the target Account ID during transfers"
        },
        "qty": {
          "type": "number",
          "description": "Optionally defines quantity bought/sold"
        },
        "price": {
          "type": "number",
          "description": "Optionally defines per-unit price"
        },
        "unit": {
          "type": "string",
          "description": "Optionally defines unit of measure"
        }
      },
      "required": ["date", "description", "amount", "type", "categoryId", "accountId"]
    },
    "Category": {
      "title": "Category",
      "description": "A transactional classification tag",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The display name of the category"
        },
        "type": {
          "type": "string",
          "enum": ["income", "expense", "transfer"],
          "description": "The type of transaction this category applies to"
        },
        "icon": {
          "type": "string",
          "description": "Lucide icon component name to render"
        },
        "color": {
          "type": "string",
          "description": "The color tag in hex format"
        }
      },
      "required": ["name", "type", "icon", "color"]
    },
    "Account": {
      "title": "Account",
      "description": "A financial account or cash wallet source",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Account display name"
        },
        "description": {
          "type": "string",
          "description": "The account's purpose description"
        }
      },
      "required": ["name", "description"]
    }
  },
  "firestore": {
    "transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "All financial transactions recorded in the petty cash"
    },
    "categories/{categoryId}": {
      "schema": "Category",
      "description": "Categories for grouping transaction entries"
    },
    "accounts/{accountId}": {
      "schema": "Account",
      "description": "The distinct petty cash or bank accounts"
    }
  }
}
