rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Schema Validation Helpers
    function isValidTransaction(t) {
      return t.keys().hasAll(['date', 'description', 'amount', 'type', 'categoryId', 'accountId'])
        && t.keys().size() <= 12
        && t.date is string && t.date.size() <= 30
        && t.description is string && t.description.size() <= 2000
        && t.amount is int && t.amount >= 0
        && t.type in ['income', 'expense', 'transfer']
        && t.categoryId is string && t.categoryId.size() <= 128
        && t.accountId is string && t.accountId.size() <= 128
        && (!('toAccountId' in t) || (t.toAccountId is string && t.toAccountId.size() <= 128))
        && (!('qty' in t) || (t.qty is number && t.qty >= 0))
        && (!('price' in t) || (t.price is number && t.price >= 0))
        && (!('unit' in t) || (t.unit is string && t.unit.size() <= 50));
    }

    function isValidCategory(c) {
      return c.keys().hasAll(['name', 'type', 'icon', 'color'])
        && c.keys().size() <= 5
        && c.name is string && c.name.size() <= 100
        && c.type in ['income', 'expense', 'transfer']
        && c.icon is string && c.icon.size() <= 100
        && c.color is string && c.color.size() <= 7;
    }

    function isValidAccount(a) {
      return a.keys().hasAll(['name', 'description'])
        && a.keys().size() <= 3
        && a.name is string && a.name.size() <= 100
        && a.description is string && a.description.size() <= 1000;
    }

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Match patterns
    match /transactions/{transactionId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && isValidId(transactionId)
        && isValidTransaction(request.resource.data);
      allow delete: if isSignedIn() && isValidId(transactionId);
    }

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && isValidId(categoryId)
        && isValidCategory(request.resource.data);
      allow delete: if isSignedIn() && isValidId(categoryId);
    }

    match /accounts/{accountId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && isValidId(accountId)
        && isValidAccount(request.resource.data);
      allow delete: if isSignedIn() && isValidId(accountId);
    }
  }
}
