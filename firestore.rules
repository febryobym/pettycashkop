rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isValidTransaction(data) {
      return data.keys().hasAll(['date', 'description', 'amount', 'type', 'categoryId', 'accountId'])
        && data.keys().size() <= 10
        && data.date is string && data.date.size() <= 50
        && data.description is string && data.description.size() <= 500
        && (data.amount is number || data.amount is int) && data.amount >= 0
        && data.type is string && (data.type == 'income' || data.type == 'expense' || data.type == 'transfer')
        && data.categoryId is string && data.categoryId.size() <= 128
        && data.accountId is string && data.accountId.size() <= 128
        && (!data.keys().contains('toAccountId') || (data.toAccountId is string && data.toAccountId.size() <= 128))
        && (!data.keys().contains('qty') || ((data.qty is number || data.qty is int) && data.qty >= 0))
        && (!data.keys().contains('unit') || (data.unit is string && data.unit.size() <= 50))
        && (!data.keys().contains('price') || ((data.price is number || data.price is int) && data.price >= 0));
    }
    
    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'color'])
        && data.keys().size() <= 4
        && data.name is string && data.name.size() <= 100
        && data.color is string && data.color.size() <= 10;
    }
    
    function isValidAccount(data) {
      return data.keys().hasAll(['name'])
        && data.keys().size() <= 3
        && data.name is string && data.name.size() <= 100
        && (!data.keys().contains('description') || (data.description is string && data.description.size() <= 500));
    }

    match /transactions/{transactionId} {
      allow read: if true;
      allow create: if isValidId(transactionId) && isValidTransaction(incoming());
      allow update: if isValidId(transactionId) && isValidTransaction(incoming());
      allow delete: if true;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isValidId(categoryId) && isValidCategory(incoming());
      allow update: if isValidId(categoryId) && isValidCategory(incoming());
      allow delete: if true;
    }

    match /accounts/{accountId} {
      allow read: if true;
      allow create: if isValidId(accountId) && isValidAccount(incoming());
      allow update: if isValidId(accountId) && isValidAccount(incoming());
      allow delete: if true;
    }
  }
}
